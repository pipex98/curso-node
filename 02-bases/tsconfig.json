{
  "include": ["src/**/*"],
  "exclude": ["node_modules","**/*.spec.ts","**/*.test.ts"],
  "compilerOptions": {
   "target": "es2016",
    "types": ["jest"],
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist/",
    "rootDir": "src",
  },
}
